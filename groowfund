<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="color-scheme" content="dark">
<meta name="theme-color" content="#0A0E1A">
<title>GrowFund TON</title>

<!-- ═══════════════════════════════════════════════
     TELEGRAM WEB APP SDK — OBLIGATORIO PRIMERO
═══════════════════════════════════════════════ -->
<script src="https://telegram.org/js/telegram-web-app.js"></script>

<!-- TON CONNECT UI (conexión de billeteras TON) -->
<script src="https://unpkg.com/@tonconnect/ui@2.0.6/dist/tonconnect-ui.min.js"></script>

<style>
/* ═══════════════════════════════
   VARIABLES DE DISEÑO
═══════════════════════════════ */
:root {
  --navy:         #0A0E1A;
  --navy-mid:     #111827;
  --navy-light:   #1C2537;
  --ton-blue:     #0088CC;
  --ton-light:    #00AAFF;
  --diamond:      #00D4FF;
  --diamond-pale: rgba(0,212,255,0.12);
  --green:        #00E676;
  --gold:         #FFD700;
  --gold-dark:    #B8860B;
  --red:          #FF6B6B;
  --purple:       #C77DFF;
  --text:         #E8EDF5;
  --muted:        #7A8BA0;
  --glass:        rgba(255,255,255,0.04);
  --glass-b:      rgba(255,255,255,0.08);
  --r:            16px;
  --r-sm:         10px;
}

/* ═══════════════════════════════
   RESET & BASE
═══════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--navy);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -webkit-tap-highlight-color: transparent;
  user-select: none;
}

/* ═══════════════════════════════
   CANVAS PARTÍCULAS (fondo)
═══════════════════════════════ */
#canvas {
  position: fixed; inset: 0;
  pointer-events: none; z-index: 0; opacity: 0.3;
}

/* ═══════════════════════════════
   APP WRAPPER
═══════════════════════════════ */
#app {
  position: relative; z-index: 1;
  max-width: 430px; margin: 0 auto;
  min-height: 100vh; display: flex; flex-direction: column;
}

/* ═══════════════════════════════
   LOADER
═══════════════════════════════ */
#loader {
  position: fixed; inset: 0; z-index: 9999;
  background: var(--navy); display: flex;
  flex-direction: column; align-items: center; justify-content: center; gap: 16px;
}
#loader .logo-big { font-size: 56px; animation: pulse 1.4s ease infinite; }
#loader .loader-text { font-size: 14px; color: var(--muted); letter-spacing: 1px; }
@keyframes pulse { 0%,100%{transform:scale(1);filter:drop-shadow(0 0 12px rgba(0,212,255,0.4))} 50%{transform:scale(1.1);filter:drop-shadow(0 0 24px rgba(0,212,255,0.7))} }
#loader .loader-bar { width: 140px; height: 3px; background: var(--glass-b,rgba(255,255,255,0.08)); border-radius: 10px; overflow: hidden; }
#loader .lb-fill { height: 100%; width: 0; background: linear-gradient(90deg, var(--ton-blue), var(--diamond)); border-radius: 10px; animation: loadbar 1.8s ease forwards; }
@keyframes loadbar { to { width: 100%; } }

/* ═══════════════════════════════
   OVERLAY BIENVENIDA
═══════════════════════════════ */
.overlay {
  position: fixed; inset: 0; z-index: 500;
  background: rgba(10,14,26,0.96);
  backdrop-filter: blur(24px);
  display: flex; align-items: flex-end; padding: 0;
  transition: opacity 0.3s;
}
.overlay.hidden { display: none; }
.overlay-sheet {
  background: linear-gradient(180deg, var(--navy-light) 0%, var(--navy-mid) 100%);
  border-top: 1px solid rgba(0,212,255,0.15);
  border-radius: 24px 24px 0 0;
  width: 100%; padding: 32px 24px 40px;
  animation: slideUp 0.4s cubic-bezier(.16,1,.3,1);
}
@keyframes slideUp { from{transform:translateY(100%)} to{transform:translateY(0)} }
.ov-gem { font-size: 60px; text-align: center; margin-bottom: 16px; filter: drop-shadow(0 0 24px rgba(0,212,255,0.5)); }
.ov-title { font-size: 24px; font-weight: 800; text-align: center; margin-bottom: 8px; letter-spacing: -0.5px; }
.ov-sub { font-size: 13px; color: var(--muted); text-align: center; line-height: 1.7; margin-bottom: 28px; }
.ov-features { display: flex; flex-direction: column; gap: 10px; margin-bottom: 28px; }
.ov-feat { display: flex; align-items: center; gap: 12px; background: var(--glass); border: 1px solid var(--glass-b); border-radius: 12px; padding: 12px 14px; }
.ov-feat-icon { font-size: 22px; flex-shrink: 0; }
.ov-feat-text { font-size: 12px; line-height: 1.5; color: var(--muted); }
.ov-feat-text strong { color: var(--text); display: block; font-size: 13px; margin-bottom: 1px; }
.ov-security { font-size: 11px; color: var(--muted); text-align: center; margin-top: 14px; line-height: 1.6; }
.ov-security strong { color: var(--green); }

/* ═══════════════════════════════
   HEADER
═══════════════════════════════ */
.header {
  padding: 14px 18px 12px;
  display: flex; align-items: center; justify-content: space-between;
  border-bottom: 1px solid var(--glass-b);
  background: rgba(10,14,26,0.88);
  backdrop-filter: blur(20px);
  position: sticky; top: 0; z-index: 100;
}
.logo { display: flex; align-items: center; gap: 10px; }
.logo-icon {
  width: 34px; height: 34px;
  background: linear-gradient(135deg, var(--ton-blue), var(--diamond));
  border-radius: 10px; display: flex; align-items: center; justify-content: center;
  font-size: 17px; box-shadow: 0 0 16px rgba(0,212,255,0.3);
  flex-shrink: 0;
}
.logo-name { font-size: 17px; font-weight: 800; letter-spacing: -0.3px; background: linear-gradient(90deg,#fff 50%, var(--diamond)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
.logo-tag { font-size: 9px; color: var(--muted); letter-spacing: 0.5px; margin-top: -2px; }

/* TON Connect button — sobreescribir estilos del SDK */
#ton-connect-root tc-root { --tc-font-family: -apple-system, sans-serif; }
#ton-connect-root button {
  background: var(--glass) !important;
  border: 1px solid var(--glass-b) !important;
  border-radius: 20px !important;
  color: var(--muted) !important;
  font-size: 11px !important;
  padding: 6px 12px !important;
  height: auto !important;
  min-width: 0 !important;
  max-width: 130px !important;
}

/* ═══════════════════════════════
   TABS
═══════════════════════════════ */
.tabs {
  display: flex; gap: 0; padding: 10px 14px;
  background: rgba(10,14,26,0.7); backdrop-filter: blur(10px);
  overflow-x: auto; scrollbar-width: none;
  border-bottom: 1px solid var(--glass-b);
}
.tabs::-webkit-scrollbar { display: none; }
.tab {
  flex: 1; min-width: fit-content; padding: 7px 13px;
  border-radius: 20px; font-size: 11px; font-weight: 700;
  color: var(--muted); cursor: pointer; transition: all 0.2s;
  white-space: nowrap; text-align: center; border: 1px solid transparent;
}
.tab.active {
  background: linear-gradient(135deg, var(--ton-blue), var(--diamond));
  color: white; box-shadow: 0 3px 12px rgba(0,136,204,0.4);
}

/* ═══════════════════════════════
   CONTENT AREAS
═══════════════════════════════ */
.content { flex: 1; padding: 14px 16px; display: none; animation: fadeIn 0.2s ease; }
.content.active { display: block; }
@keyframes fadeIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:none} }
.spacer { height: 90px; }

/* ═══════════════════════════════
   CARDS
═══════════════════════════════ */
.card {
  background: var(--glass); border: 1px solid var(--glass-b);
  border-radius: var(--r); padding: 18px; margin-bottom: 12px;
  backdrop-filter: blur(10px); transition: border-color 0.2s, transform 0.15s;
}
.card:active { transform: scale(0.99); }

.hero-card {
  background: linear-gradient(135deg, rgba(0,136,204,0.14), rgba(0,212,255,0.07));
  border: 1px solid rgba(0,212,255,0.2);
  border-radius: var(--r); padding: 22px; margin-bottom: 14px;
  position: relative; overflow: hidden;
}
.hero-card::after {
  content: ''; position: absolute; top: -50px; right: -50px;
  width: 160px; height: 160px;
  background: radial-gradient(circle, rgba(0,212,255,0.1), transparent 70%);
  pointer-events: none;
}

.section-title {
  font-size: 10px; font-weight: 800; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--muted); margin-bottom: 10px; padding-left: 2px;
}

/* ═══════════════════════════════
   HERO STATS
═══════════════════════════════ */
.hero-label { font-size: 10px; color: var(--muted); letter-spacing: 0.5px; margin-bottom: 4px; }
.hero-value { font-size: 30px; font-weight: 800; letter-spacing: -1px; background: linear-gradient(90deg,white,var(--diamond)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
.hero-sub { font-size: 11px; color: var(--muted); margin-top: 3px; }

.diamond-row {
  display: flex; align-items: center; gap: 10px;
  background: rgba(0,212,255,0.06); border: 1px solid rgba(0,212,255,0.15);
  border-radius: var(--r-sm); padding: 12px 14px; margin-bottom: 12px;
}
.dm-icon { font-size: 24px; filter: drop-shadow(0 0 8px rgba(0,212,255,0.6)); }
.dm-amount { font-size: 22px; font-weight: 800; color: var(--diamond); }
.dm-label { font-size: 10px; color: var(--muted); }
.dm-right { margin-left: auto; text-align: right; font-size: 10px; color: var(--muted); line-height: 1.5; }

/* ═══════════════════════════════
   BADGES DE ROL
═══════════════════════════════ */
.roles-row { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }
.badge { display: flex; align-items: center; gap: 5px; padding: 5px 11px; border-radius: 20px; font-size: 10px; font-weight: 700; border: 1px solid; }
.badge.donador  { background:rgba(0,212,255,0.08);  border-color:rgba(0,212,255,0.3);  color:var(--diamond); }
.badge.emprendedor { background:rgba(255,215,0,0.08); border-color:rgba(255,215,0,0.3); color:var(--gold); }
.badge.ballena  { background:rgba(199,125,255,0.1); border-color:rgba(199,125,255,0.35);color:var(--purple); }
.badge.none     { background:var(--glass);           border-color:var(--glass-b);       color:var(--muted); font-size:11px; }

/* ═══════════════════════════════
   STATS GRID
═══════════════════════════════ */
.stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 9px; margin-bottom: 14px; }
.stat { background: var(--glass); border: 1px solid var(--glass-b); border-radius: var(--r-sm); padding: 13px; }
.stat-l { font-size: 9px; color: var(--muted); letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 4px; }
.stat-v { font-size: 19px; font-weight: 800; }
.c-cyan { color: var(--diamond); } .c-green { color: var(--green); } .c-gold { color: var(--gold); } .c-purple { color: var(--purple); }

/* ═══════════════════════════════
   PROGRESS
═══════════════════════════════ */
.prog-wrap { margin: 9px 0; }
.prog-info { display: flex; justify-content: space-between; font-size: 10px; color: var(--muted); margin-bottom: 5px; }
.prog-bar { height: 5px; background: var(--glass-b); border-radius: 10px; overflow: hidden; }
.prog-fill { height: 100%; border-radius: 10px; background: linear-gradient(90deg, var(--ton-blue), var(--diamond)); transition: width 1s ease; }
.prog-fill.green { background: linear-gradient(90deg, #00b248, var(--green)); }

/* ═══════════════════════════════
   PROYECTO CARD
═══════════════════════════════ */
.p-card {
  background: var(--navy-light); border: 1px solid var(--glass-b);
  border-radius: var(--r); padding: 15px; margin-bottom: 11px;
  cursor: pointer; transition: all 0.2s;
}
.p-card:hover, .p-card:active { border-color: rgba(0,136,204,0.4); transform: translateY(-1px); }
.p-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
.p-name { font-size: 14px; font-weight: 800; margin-bottom: 2px; }
.p-cat { font-size: 9px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px; }
.p-status { font-size: 9px; font-weight: 700; padding: 3px 8px; border-radius: 10px; white-space: nowrap; }
.ps-activo   { background:rgba(0,230,118,0.1);  color:var(--green); }
.ps-votacion { background:rgba(255,215,0,0.1);  color:var(--gold);  }
.ps-exito    { background:rgba(0,212,255,0.1);  color:var(--diamond);}
.p-desc { font-size: 11px; color: var(--muted); line-height: 1.55; margin-bottom: 11px; }
.p-meta { display: flex; gap: 10px; font-size: 10px; color: var(--muted); flex-wrap: wrap; }

/* ═══════════════════════════════
   BOTONES
═══════════════════════════════ */
.btn { width:100%; padding:14px; border-radius:var(--r-sm); font-size:14px; font-weight:800; letter-spacing:0.2px; cursor:pointer; border:none; transition:all 0.18s; font-family:inherit; }
.btn-primary { background:linear-gradient(135deg,var(--ton-blue),var(--diamond)); color:white; box-shadow:0 4px 18px rgba(0,136,204,0.35); }
.btn-primary:active { transform:scale(0.98); }
.btn-secondary { background:var(--glass); border:1px solid var(--glass-b); color:var(--text); }
.btn-gold { background:linear-gradient(135deg,var(--gold-dark),var(--gold)); color:#0A0E1A; font-weight:900; box-shadow:0 4px 18px rgba(255,215,0,0.2); }
.btn-green { background:rgba(0,230,118,0.12); border:1px solid rgba(0,230,118,0.3); color:var(--green); font-weight:800; }
.btn-red { background:rgba(255,107,107,0.12); border:1px solid rgba(255,107,107,0.3); color:var(--red); font-weight:800; }
.btn-sm { padding:9px 16px; width:auto; font-size:12px; border-radius:var(--r-sm); }

/* ═══════════════════════════════
   INPUTS
═══════════════════════════════ */
.inp-label { font-size:10px; color:var(--muted); margin-bottom:5px; display:block; letter-spacing:0.5px; text-transform:uppercase; }
.inp {
  width:100%; background:var(--navy-light); border:1px solid var(--glass-b);
  border-radius:var(--r-sm); padding:12px 14px; color:var(--text);
  font-size:15px; font-family:inherit; outline:none; transition:border-color 0.2s;
  -webkit-appearance:none;
}
.inp:focus { border-color:var(--ton-blue); }
.inp::placeholder { color:var(--muted); }
textarea.inp { min-height:90px; resize:vertical; }
.inp-group { margin-bottom:12px; }
.chips { display:flex; gap:7px; margin-top:7px; flex-wrap:wrap; }
.chip {
  padding:7px 13px; background:var(--glass); border:1px solid var(--glass-b);
  border-radius:var(--r-sm); font-size:11px; font-weight:600; color:var(--muted);
  cursor:pointer; transition:all 0.18s;
}
.chip.sel, .chip:active { border-color:var(--ton-blue); color:var(--ton-light); background:rgba(0,136,204,0.1); }

/* ═══════════════════════════════
   DIAMOND PREVIEW
═══════════════════════════════ */
.dm-preview {
  background:rgba(0,212,255,0.06); border:1px dashed rgba(0,212,255,0.25);
  border-radius:var(--r-sm); padding:12px 14px; margin:10px 0;
  display:flex; align-items:center; justify-content:space-between;
}
.dm-preview-val { font-size:17px; font-weight:800; color:var(--diamond); }

/* ═══════════════════════════════
   INFO BOX
═══════════════════════════════ */
.info-box {
  background:rgba(0,136,204,0.07); border:1px solid rgba(0,136,204,0.18);
  border-radius:var(--r-sm); padding:11px 13px; font-size:11px;
  color:var(--muted); line-height:1.6; margin:9px 0;
}
.info-box strong { color:var(--ton-light); }

/* ═══════════════════════════════
   VOTE CARD
═══════════════════════════════ */
.vote-card {
  background:var(--navy-light); border:1px solid var(--glass-b);
  border-radius:var(--r); padding:16px; margin-bottom:11px;
}
.vote-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
.vote-title { font-size:13px; font-weight:800; }
.vote-timer { font-size:10px; color:var(--gold); background:rgba(255,215,0,0.1); padding:3px 9px; border-radius:10px; }
.vote-desc { font-size:11px; color:var(--muted); line-height:1.6; margin-bottom:12px; }
.vote-btns { display:flex; gap:8px; }
.v-yes { flex:1; padding:10px; background:rgba(0,230,118,0.1); border:1px solid rgba(0,230,118,0.28); color:var(--green); border-radius:var(--r-sm); font-size:12px; font-weight:800; cursor:pointer; transition:background 0.18s; font-family:inherit; }
.v-no  { flex:1; padding:10px; background:rgba(255,107,107,0.1); border:1px solid rgba(255,107,107,0.28); color:var(--red); border-radius:var(--r-sm); font-size:12px; font-weight:800; cursor:pointer; transition:background 0.18s; font-family:inherit; }
.v-yes:active { background:rgba(0,230,118,0.22); }
.v-no:active  { background:rgba(255,107,107,0.22); }
.vote-pct { display:flex; gap:8px; font-size:10px; margin-top:8px; }

/* ═══════════════════════════════
   RANKING
═══════════════════════════════ */
.rank-item { display:flex; align-items:center; gap:11px; padding:11px 0; border-bottom:1px solid var(--glass-b); }
.rank-item:last-child { border-bottom:none; }
.rank-n { width:22px; text-align:center; font-size:12px; font-weight:800; color:var(--muted); }
.rank-n.top { color:var(--gold); }
.rank-av { width:34px; height:34px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:15px; flex-shrink:0; }
.rank-info { flex:1; min-width:0; }
.rank-name { font-size:12px; font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.rank-role { font-size:9px; color:var(--muted); }
.rank-dm { font-size:12px; font-weight:800; color:var(--diamond); white-space:nowrap; }

/* ═══════════════════════════════
   WHITEPAPER
═══════════════════════════════ */
.wp-pill { display:inline-flex; align-items:center; gap:6px; background:rgba(0,136,204,0.1); border:1px solid rgba(0,136,204,0.22); border-radius:20px; padding:5px 12px; font-size:10px; font-weight:700; color:var(--ton-light); margin-bottom:14px; }
.wp-h3 { font-size:12px; font-weight:800; color:var(--diamond); margin-bottom:7px; letter-spacing:0.3px; text-transform:uppercase; }
.wp-p { font-size:11px; color:var(--muted); line-height:1.75; margin-bottom:8px; }
.wp-table { width:100%; border-collapse:collapse; font-size:10px; margin:8px 0; }
.wp-table th { color:var(--muted); font-weight:700; padding:5px 7px; border-bottom:1px solid var(--glass-b); text-align:left; letter-spacing:0.4px; }
.wp-table td { padding:7px 7px; border-bottom:1px solid rgba(255,255,255,0.03); }
.wp-table tr:last-child td { border-bottom:none; }
.dist-row { display:flex; align-items:center; gap:9px; margin-bottom:7px; }
.dist-label { font-size:10px; color:var(--muted); width:120px; flex-shrink:0; }
.dist-track { flex:1; height:7px; background:var(--glass-b); border-radius:10px; overflow:hidden; }
.dist-fill { height:100%; border-radius:10px; }
.dist-pct { font-size:10px; font-weight:800; width:28px; text-align:right; }

/* ═══════════════════════════════
   PERFIL
═══════════════════════════════ */
.profile-header {
  background:linear-gradient(135deg,rgba(0,136,204,0.12),rgba(0,212,255,0.06));
  border:1px solid rgba(0,212,255,0.15); border-radius:var(--r);
  padding:20px; margin-bottom:12px; text-align:center;
}
.profile-avatar { font-size:52px; margin-bottom:10px; }
.profile-name { font-size:18px; font-weight:800; margin-bottom:3px; }
.profile-address { font-size:10px; color:var(--muted); font-family:monospace; }
.ref-box { background:var(--navy-light); border:1px solid var(--glass-b); border-radius:var(--r-sm); padding:12px 14px; display:flex; align-items:center; gap:10px; cursor:pointer; }
.ref-code { font-size:13px; font-weight:800; color:var(--diamond); font-family:monospace; flex:1; }
.ref-copy { font-size:10px; color:var(--muted); }

/* ═══════════════════════════════
   MODAL (hoja inferior)
═══════════════════════════════ */
.modal { position:fixed; inset:0; z-index:600; display:none; align-items:flex-end; background:rgba(0,0,0,0.55); backdrop-filter:blur(6px); }
.modal.open { display:flex; }
.modal-body { background:var(--navy-mid); border-top:1px solid var(--glass-b); border-radius:20px 20px 0 0; width:100%; padding:22px 18px 36px; max-height:82vh; overflow-y:auto; animation:slideUp 0.3s cubic-bezier(.16,1,.3,1); }
.modal-handle { width:38px; height:4px; background:var(--glass-b); border-radius:10px; margin:0 auto 18px; }
.modal-title { font-size:16px; font-weight:800; margin-bottom:3px; }
.modal-sub { font-size:11px; color:var(--muted); margin-bottom:18px; line-height:1.5; }

/* ═══════════════════════════════
   TOAST
═══════════════════════════════ */
.toast {
  position:fixed; bottom:90px; left:50%; transform:translateX(-50%) translateY(16px);
  background:var(--navy-light); border:1px solid var(--glass-b);
