}

/* ═══════════════════════════════════
   CANVAS PARTÍCULAS FLOTANTES
═══════════════════════════════════ */
const canvas = document.getElementById('canvas');
const ctx = canvas.getContext('2d');

function resize() { canvas.width = innerWidth; canvas.height = innerHeight; }
resize(); window.addEventListener('resize', resize);

class Particle {
  constructor() { this.reset(true); }
  reset(init) {
    this.x = Math.random() * canvas.width;
    this.y = init ? Math.random() * canvas.height : canvas.height + 10;
    this.s = Math.random() * 3.5 + 1.5;
    this.vy = Math.random() * 0.35 + 0.08;
    this.vx = (Math.random() - 0.5) * 0.25;
    this.o = Math.random() * 0.45 + 0.08;
    this.r = Math.random() * Math.PI;
  }
  update() { this.y -= this.vy; this.x += this.vx; this.r += 0.01; if (this.y < -10) this.reset(); }
  draw() {
    ctx.save(); ctx.globalAlpha = this.o;
    ctx.translate(this.x, this.y); ctx.rotate(this.r);
    ctx.fillStyle = Math.random() > 0.5 ? '#00D4FF' : '#0088CC';
    ctx.fillRect(-this.s/2, -this.s/2, this.s, this.s);
    ctx.restore();
  }
}
const particles = Array.from({length:45}, () => new Particle());
(function loop() { ctx.clearRect(0,0,canvas.width,canvas.height); particles.forEach(p=>{p.update();p.draw();}); requestAnimationFrame(loop); })();

